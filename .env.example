# ── Provider API keys ─────────────────────────────────────────────────────────
# Providers with a missing key are skipped gracefully; at least one must be set.

# Vast.ai — https://cloud.vast.ai/account/
VAST_API_KEY=your_vast_api_key_here

# Lambda Labs — https://cloud.lambdalabs.com/api-keys
LAMBDA_LABS_API_KEY=your_lambda_labs_api_key_here

# RunPod — https://www.runpod.io/console/user/settings (API Keys tab)
RUNPOD_API_KEY=your_runpod_api_key_here

# ── Carbon intensity ──────────────────────────────────────────────────────────
# WattTime — https://www.watttime.org/api-documentation/ (free tier)
WATTTIME_USERNAME=your_watttime_username
WATTTIME_PASSWORD=your_watttime_password
